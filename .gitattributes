# Standardize line endings (LF) across all platforms
* text=auto eol=lf

# Explicitly declare text files
*.js text
*.ts text
*.tsx text
*.jsx text
*.json text
*.css text
*.html text
*.md text
*.yml text
*.yaml text

# Treat images and other binary assets as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text
*.pdf binary
*.woff binary
*.woff2 binary
